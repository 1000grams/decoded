# 🌍 Environment configuration example
# Copy to .env and replace placeholder values with actual secrets or parameters

# 🔐 AWS Secrets Manager Keys
NEWS_API_KEY_SECRET=/decoded/newsApiKey
STRIPE_SECRET_KEY_SECRET=/decoded/stripeSecret
FACEBOOK_TOKEN_SECRET=/decoded/facebookToken
INSTAGRAM_TOKEN_SECRET=/decoded/instagramToken

# 🗝️ Direct Values (Public or Frontend Safe)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
POST_IMAGE_URL=https://decodedmusic.com/default-post.jpg

# 📍 AWS Region
AWS_REGION=eu-central-1

# 🤖 Bedrock Model and AI Tooling
BEDROCK_MODEL_ID_PARAM=/decoded/bedrockModelId         # e.g. meta.llama3-70b-instruct-v1:0
POLLY_VOICE_PARAM=/decoded/pollyVoice

# 📦 S3 and Lambda Integration
S3_BUCKET_PARAM=/decoded/s3Bucket
SHORTS_BUCKET_PARAM=/decoded/shortsBucket
SHORTS_LAMBDA_PARAM=/decoded/shortsLambda

# 📧 Email Target for Pitches
PITCH_TARGET_EMAIL_PARAM=/decoded/pitchTargetEmail

# 📲 Facebook / Instagram Graph API Page Info
FACEBOOK_PAGE_IDS_PARAM=/decoded/facebookPageIds
INSTAGRAM_USER_ID_PARAM=/decoded/instagramUserId

# 🌐 API URLs (Frontend Public APIs)
REACT_APP_PITCH_API_URL=https://9zlblaqwo0.execute-api.eu-central-1.amazonaws.com/prod/pitch
REACT_APP_CATALOG_API_URL=https://2h2oj7u446.execute-api.eu-central-1.amazonaws.com/prod/catalog
REACT_APP_SIGNUP_API_URL=https://2h2oj7u446.execute-api.eu-central-1.amazonaws.com/prod/signup
REACT_APP_API_BASE=https://2h2oj7u446.execute-api.eu-central-1.amazonaws.com/prod/dashboard
